# Database
DATABASE_URL="postgresql://childbook:childbook123@localhost:5432/childbook_db"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Server
PORT=3001
NODE_ENV=development

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# CORS
FRONTEND_URL=http://localhost:5173

# Email (Nodemailer - 忘記密碼功能)
# 開發測試可用 Ethereal: https://ethereal.email/
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-ethereal-user@ethereal.email
SMTP_PASS=your-ethereal-password
EMAIL_FROM="寶寶日誌系統 <noreply@childbook.app>"

# 前端 URL (密碼重置連結用)
FRONTEND_URL=http://localhost:5173

# 重置 Token 有效時間（分鐘）
RESET_TOKEN_EXPIRES_MIN=30
